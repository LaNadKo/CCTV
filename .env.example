# ============================================================
#  CCTV Console — Configuration
#  Copy this file to .env and fill in your values
# ============================================================

# ── Domain & SSL ──────────────────────────────────────────────
# Your domain name (used for nginx and SSL certificate)
DOMAIN=cctv.example.com

# Email for Let's Encrypt SSL certificate notifications
SSL_EMAIL=admin@example.com

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=cctv
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=cctv

# ── Backend ───────────────────────────────────────────────────
# Secret key for JWT tokens (generate: openssl rand -hex 32)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Shared secret for processor API keys (generate: openssl rand -hex 24)
PROCESSOR_API_KEY=change-me-generate-with-openssl-rand-hex-24

# Enable embedded detector on backend (disable if using external processors)
ENABLE_EMBEDDED_DETECTOR=false

# Debug mode (set to true for development)
DEBUG=false

# Optional: TOTP encryption key
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=

# ── Storage ───────────────────────────────────────────────────
# Where recordings are stored on the host machine
RECORDINGS_PATH=./data/recordings
SNAPSHOTS_PATH=./data/snapshots
