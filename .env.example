# CCTV Console — Конфигурация
# Скопируйте в .env:  cp .env.example .env
# Или запустите install.sh — он создаст .env автоматически

DOMAIN=localhost
POSTGRES_USER=cctv
POSTGRES_PASSWORD=cctv
POSTGRES_DB=cctv
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
PROCESSOR_API_KEY=changeme-generate-with-openssl-rand-hex-24
ENABLE_EMBEDDED_DETECTOR=false
DEBUG=false
TOTP_ENCRYPTION_KEY=
RECORDINGS_PATH=./data/recordings
SNAPSHOTS_PATH=./data/snapshots
