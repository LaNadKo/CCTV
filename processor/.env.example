# ============================================================
#  CCTV Processor — Configuration
#  Copy to .env and fill in your values
# ============================================================

# URL of your CCTV Console server
BACKEND_URL=https://cctv.example.com

# API key (get from CCTV Console → API-ключи page, or use shared secret from server .env)
API_KEY=your-api-key-here

# Name for this processor (shown in admin panel)
PROCESSOR_NAME=processor-1

# Max concurrent camera workers
MAX_WORKERS=4

# Advanced settings (usually no need to change)
POLL_INTERVAL=10
HEARTBEAT_INTERVAL=30
MOTION_THRESHOLD=25.0
MOTION_MIN_AREA=500
FACE_SCAN_INTERVAL=5
