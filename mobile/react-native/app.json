{
  "expo": {
    "name": "CCTV Console",
    "slug": "cctv-console",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "cctv",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1021"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cctv.console"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b1021",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.cctv.console",
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Доступ к фото для загрузки изображений лиц"
        }
      ],
      "expo-build-properties"
    ]
  }
}
